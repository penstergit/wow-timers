# Copy this file to .env and fill in your four bot tokens.
# Get tokens from https://discord.com/developers/applications

DISCORD_BOT_TOKEN=your_bg_bot_token_here
DISCORD_BOT_TOKEN_ARENA=your_arena_bot_token_here
DISCORD_BOT_TOKEN_DMF=your_dmf_bot_token_here
DISCORD_BOT_TOKEN_FISHING=your_fishing_bot_token_here

# ── Re-invite URLs (needed for /setup commands + alert pings) ──────────────
#
# The bots need these permissions:
#   Change Nickname (67108864) + Send Messages (2048) + View Channel (1024)
#   + Read Message History (65536) + Use Application Commands (2147483648)
#   = 2214661120
#
# BG Weekend:
#   https://discord.com/api/oauth2/authorize?client_id=1488647384337748159&permissions=2214661120&scope=bot%20applications.commands
#
# Arena Grand Master:
#   https://discord.com/api/oauth2/authorize?client_id=1488654508090458204&permissions=2214661120&scope=bot%20applications.commands
#
# Darkmoon Faire:
#   https://discord.com/api/oauth2/authorize?client_id=1488655769036521642&permissions=2214661120&scope=bot%20applications.commands
#
# STV Fishing:
#   https://discord.com/api/oauth2/authorize?client_id=1488655957277020420&permissions=2214661120&scope=bot%20applications.commands
